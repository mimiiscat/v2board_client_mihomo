{
  "name": "v2board-client",
  "version": "1.0.0",
  "main": "main.js",
  "author": "v2board",
  "license": "MIT",
  "description": "v2Board Mihomo Desktop Client",
  "dependencies": {
    "express": "^4.18.2",
    "js-yaml": "^4.1.0",
    "kill-port": "^2.0.1",
    "axios": "^1.6.0"
  },
  "build": {
    "appId": "com.v2board.client",
    "productName": "v2Board",
    "copyright": "Copyright © 2025",
    "directories": {
      "output": "build"
    },
    "extraResources": [
      {
        "from": "../libs/${env.TARGET_ARCH_DIR}",
        "to": "./libs/${env.TARGET_ARCH_DIR}"
      },
      {
        "from": "../libs/geo",
        "to": "./libs/geo"
      },
      {
        "from": "../libs/config",
        "to": "./libs/config"
      }
    ],
    "files": [
      "main.js",
      "package.json",
      "dist/**/*",
      "assets/**/*"
    ],
    "dmg": {
      "contents": [
        { "x": 410, "y": 150, "type": "link", "path": "/Applications" },
        { "x": 130, "y": 150, "type": "file" }
      ]
    },
    "mac": {
      "icon": "../res/icon.icns",
      "category": "public.category.internet"
    },
    "win": {
      "icon": "../res/icon.ico",
      "target": ["nsis"]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
